rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow authenticated users to read and write their own data
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Allow public read and write access for predictions and feedback (for development/testing)
    match /predictions/{document} {
      allow read, write: if true;
    }

    match /feedback/{document} {
      allow read, write: if true;
    }

    match /model_versions/{document} {
      allow read, write: if true;
    }

    match /agroforestry_plans/{document} {
      allow read, write: if true;
    }

    match /users/{document} {
      allow read, write: if true;
    }

    match /ai_recommendations/{document} {
      allow read, write: if true;
    }

    match /user_feedback/{document} {
      allow read, write: if true;
    }

    match /prediction_feedback/{document} {
      allow read, write: if true;
    }

    // Allow public read for land layout maps
    match /land_layout_maps/{document} {
      allow read, write: if true;
    }
  }
}